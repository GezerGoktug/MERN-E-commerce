{
    "name": "@forever/plugins",
    "version": "1.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsup index.ts --format esm --dts --clean"
    },
    "exports": {
        ".": {
            "types": "./index.ts",
            "import": "./index.ts"
        },
        "./utils": {
            "types": "./src/utils.ts",
            "import": "./src/utils.ts"
        }
    },
    "devDependencies": {
        "vite": "7.3.1",
        "tsup": "8.5.1"
    }
}