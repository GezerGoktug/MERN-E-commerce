{
    "name": "forever-monorepo",
    "private": true,
    "packageManager": "pnpm@10.23.0",
    "scripts": {
        "dev:main": "pnpm --filter main dev",
        "dev:admin": "pnpm --filter admin dev",
        "dev:checkout": "pnpm --filter checkout dev",
        "prod:admin": "pnpm --filter admin preview",
        "prod:main": "pnpm --filter main preview",
        "prod:checkout": "pnpm --filter checkout preview",
        "i:admin": "pnpm --filter admin install",
        "i:main": "pnpm --filter main install",
        "i:checkout": "pnpm --filter checkout install",
        "build": "pnpm -r build"
    },
    "devDependencies": {
        "sass": "^1.97.3",
        "typescript": "^5.9.3"
    },
    "pnpm": {
        "overrides": {
            "react": "18.3.1",
            "react-dom": "18.3.1",
            "react-router-dom": "7.0.2",
            "zustand": "5.0.3",
            "axios": "1.13.5",
            "@tanstack/react-query": "5.64.2"
        }
    }
}