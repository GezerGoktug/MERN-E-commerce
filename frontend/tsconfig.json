{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@forever/api": ["packages/libs/api/src/index.ts"],
      "@forever/api/*": ["packages/libs/api/src/*"],

      "@forever/common-utils": ["packages/libs/common-utils/src/index.ts"],
      "@forever/common-utils/*": ["packages/libs/common-utils/src/*"],

      "@forever/hook-kit": ["packages/libs/hook-kit/src/index.ts"],
      "@forever/hook-kit/*": ["packages/libs/hook-kit/src/*"],

      "@forever/query-kit": ["packages/libs/query-kit/src/index.ts"],
      "@forever/query-kit/*": ["packages/libs/query-kit/src/*"],

      "@forever/sass-utils": ["packages/libs/sass-utils/src/index.ts"],
      "@forever/sass-utils/*": ["packages/libs/sass-utils/src/*"],

      "@forever/speech": ["packages/libs/speech/src/index.ts"],
      "@forever/speech/*": ["packages/libs/speech/src/*"],

      "@forever/storage-kit": ["packages/libs/storage-kit/src/index.ts"],
      "@forever/storage-kit/*": ["packages/libs/storage-kit/src/*"],

      "@forever/theme-kit": ["packages/libs/theme-kit/src/index.ts"],
      "@forever/theme-kit/*": ["packages/libs/theme-kit/src/*"],

      "@forever/ui-kit": ["packages/libs/ui-kit/src/index.ts"],
      "@forever/ui-kit/*": ["packages/libs/ui-kit/src/*"],

      "@forever/plugins": ["packages/config/plugins/index.ts"],
      "@forever/plugins/*": ["packages/config/plugins/src/*"]
    }
  }
}
